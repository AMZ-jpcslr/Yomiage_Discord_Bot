FROM voicevox/voicevox_engine:cpu-ubuntu20.04-latest

# Railwayの動的ポート対応
ENV PORT=50021
EXPOSE $PORT

# VoiceVoxエンジンの作業ディレクトリ設定
WORKDIR /opt/voicevox_engine

# 🚨 全てのドキュメントを削除し、catコマンドも無効化
RUN rm -rf /opt/voicevox_engine/*.md /opt/voicevox_engine/README* || true && \
    rm -rf /opt/voicevox_engine/docs || true

# 最小限の設定
ENV PYTHONUNBUFFERED=1

# 最小限の起動コマンド（ログ最少）
CMD ["/usr/bin/python3", "run.py", "--host", "0.0.0.0", "--port", "50021"]
