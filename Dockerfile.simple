# シンプルなDockerfile�E�地図生�Eなし版�E�E
FROM node:18-alpine

# 基本パッケージのみインスト�Eル
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    git

# 作業チE��レクトリ設宁E
WORKDIR /app

# package.jsonをコピ�E
COPY package*.json ./

# 依存関係をインスト�Eル
RUN npm install

# ソースコードをコピ�E
COPY . .

# スクリプトに実行権限を付丁E
RUN chmod +x scripts/postbuild.sh

# TypeScriptをコンパイル
RUN npm run build

# 画像用チE��レクトリ作�E
RUN mkdir -p /app/generated_images && \
    mkdir -p /app/generated_maps

# 環墁E��数設宁E
ENV NODE_ENV=production
ENV SKIP_MAP_GENERATION=true
ENV FORCE_MAP_GENERATION=false

# ポ�Eト�E閁E
EXPOSE 3000

# ボット起勁E
CMD ["npm", "run", "start:prod"]
