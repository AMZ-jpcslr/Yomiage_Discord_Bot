## Local development template (DO NOT commit real secrets)
##
## - Local: copy this file to `.env` and fill values.
## - Railway: set values as Variables (Keys). The app reads `process.env.*`.

# Discord Bot Token
DISCORD_TOKEN=

# Discord Application (Client) ID
# (fallback supported: DISCORD_CLIENT_ID)
CLIENT_ID=

# Optional: register commands to a specific guild (faster to reflect)
GUILD_ID=

# Bot environment
NODE_ENV=development

# Earthquake map generation
FORCE_MAP_GENERATION=true
# SKIP_MAP_GENERATION=false

# Memory setting (optional)
NODE_OPTIONS=--max-old-space-size=1024

# VoiceVox Web API key (optional)
VOICEVOX_API_KEY=

# Health check port (optional)
PORT=3000
