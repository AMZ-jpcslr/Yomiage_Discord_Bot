{
  "name": "discord_bot",
  "version": "1.0.0",
  "main": "build/main.js",
  "scripts": {
    "test": "ts-node src/main.ts",
    "start": "node build/main.js",
    "start:prod": "NODE_ENV=production node build/main.js",
    "build": "tsc -p . && npm run postbuild",
    "postbuild": "bash scripts/postbuild.sh 2>/dev/null || node -e \"const fs=require('fs'),path=require('path');if(fs.existsSync('build/src')){fs.readdirSync('build/src',{withFileTypes:true}).forEach(f=>{const src=path.join('build/src',f.name),dest=path.join('build',f.name);f.isDirectory()?(fs.existsSync(dest)||fs.mkdirSync(dest,{recursive:true}),fs.cpSync(src,dest,{recursive:true})):fs.copyFileSync(src,dest)})}\"",
    "compile": "tsc -p ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "eslint": "^9.30.0",
    "globals": "^16.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0"
  },
  "dependencies": {
    "@discordjs/rest": "^2.5.1",
    "@discordjs/voice": "^0.18.0",
    "@types/ws": "^8.18.1",
    "discord-api-types": "^0.38.12",
    "discord.js": "^14.21.0",
    "dotenv": "^16.6.1",
    "libsodium-wrappers": "^0.7.15",
    "opusscript": "^0.0.8",
    "undici": "^7.11.0",
    "ws": "^8.18.3"
  },
  "description": ""
}
