# Railway環境でのCanvas設定用環境変数

# Canvas関連のビルド設定
CANVAS_PREBUILT=false
# または以下を追加
# npm config set canvas_binary_host_mirror https://registry.npmjs.org/-/binary/canvas/

# Node.js設定
NODE_ENV=production
FORCE_MAP_GENERATION=true

# メモリ設定
NODE_OPTIONS=--max-old-space-size=2048

# PKG_CONFIG_PATH for Canvas
PKG_CONFIG_PATH=/usr/lib/x86_64-linux-gnu/pkgconfig:/usr/share/pkgconfig

# Railway専用設定
RAILWAY_ENVIRONMENT=true
